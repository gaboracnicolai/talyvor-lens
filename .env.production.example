# Talyvor Lens — production environment template.
# Copy to `.env` and fill in your values:
#   cp .env.production.example .env

# ────────────────────────────────────────────────────────────
# REQUIRED: at least one LLM API key.
# Without any provider key, the proxy will refuse to forward.
# ────────────────────────────────────────────────────────────
LENS_OPENAI_API_KEY=sk-...
LENS_ANTHROPIC_API_KEY=sk-ant-...

# ────────────────────────────────────────────────────────────
# OPTIONAL: additional providers.
# Each missing key just disables that provider's /v1/proxy/* route
# (returns 503). Other providers keep working.
# ────────────────────────────────────────────────────────────
LENS_GOOGLE_API_KEY=AIza...
LENS_MISTRAL_API_KEY=
LENS_GROQ_API_KEY=gsk_...

# AWS Bedrock — only set if you're running Claude through AWS IAM.
LENS_AWS_REGION=us-east-1
LENS_AWS_ACCESS_KEY_ID=
LENS_AWS_SECRET_ACCESS_KEY=

# Self-hosted vLLM endpoint — only set if you run vLLM somewhere.
# vLLM API key is optional; many vLLM deployments run without auth on
# private networks.
LENS_VLLM_BASE_URL=
LENS_VLLM_API_KEY=

# Local model routing via Ollama (running on the host).
# Uncomment if you want Lens to route easy prompts to a local model.
# LENS_OLLAMA_URL=http://host.docker.internal:11434

# ────────────────────────────────────────────────────────────
# REQUIRED: database password. There is NO default — the stack refuses to
# start (compose ${POSTGRES_PASSWORD:?}) when this is unset or empty, so a
# weak default can never silently reach production. Generate a strong one:
#   openssl rand -hex 32
# ────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=

# ────────────────────────────────────────────────────────────
# REQUIRED: public hostname for TLS. The Caddy front door provisions a
# Let's Encrypt certificate for this name automatically on first boot and
# terminates HTTPS on :443, proxying to lens. Point a DNS A record at the VM
# first. Use `localhost` for a local run (Caddy then serves an internal-CA cert;
# curl with -k). The stack fails closed if this is unset.
# ────────────────────────────────────────────────────────────
LENS_DOMAIN=

# (Caddy provisions and auto-renews the Let's Encrypt certificate for LENS_DOMAIN
# with no ACME account email required. To also receive expiry emails, add a
# `{ email you@addr }` global block to deploy/caddy/Caddyfile.)

# ────────────────────────────────────────────────────────────
# ADMIN god-key (LENS_API_KEY). LEAVE UNSET on an internet-facing host: with no
# key, every admin route fails closed (401) — there is no admin surface to
# attack. See internal/auth/manager.go: admin is granted only when the request
# key EXACTLY matches a NON-EMPTY LENS_API_KEY. You only need it for the one-time
# bootstrap (create the first workspace + mint a key); do that over an SSH tunnel
# to the loopback :8080, then unset it again. See docs/remote-host.md.
# LENS_API_KEY=

# ────────────────────────────────────────────────────────────
# PRODUCTION identity keys. Optional for a single instance (Lens generates an
# ephemeral key when empty), but then a RESTART invalidates everything they sign:
#   - LENS_JWT_PRIVATE_KEY: without it, JWTs (POST /v1/auth/token) are signed with
#     an ephemeral EC P-256 key and stop verifying after a restart. Generate one:
#       openssl ecparam -name prime256v1 -genkey -noout -out ec-private.pem
#       LENS_JWT_PRIVATE_KEY=$(cat ec-private.pem)   # paste the PEM
#   - LENS_POVI_CHALLENGE_KEY: without it, node challenge signing uses an ephemeral
#     ed25519 key and a restart invalidates node-pinned pubkeys. Base64 of a 32-byte
#     seed:  LENS_POVI_CHALLENGE_KEY=$(head -c32 /dev/urandom | base64)
# Both are REQUIRED (hard fail at boot) when LENS_HA_ENABLED=true.
# LENS_JWT_PRIVATE_KEY=
# LENS_POVI_CHALLENGE_KEY=

# OPTIONAL: enable the admin-only comped-LXC grant endpoint (POST /v1/admin/lxc/grant),
# needed to fund a fresh workspace's first request without Stripe. Default off (empty).
# LENS_ADMIN_LXC_GRANT_ENABLED=true

# OPTIONAL: routing-pattern mining/earning. Without LENS_PATTERN_MINING_ENABLED the opt-in
# route (POST .../pattern-mining/opt-in) returns 503, so nobody can opt in and pattern
# earning is silently zero even though it is armed. Set MINING=true to open the route;
# EARNING is on by default under the economy (unset = default TRUE — do NOT set it to a
# blank value expecting to disable it; use "false"). CAPTURE (the mint-free write) is a
# third, independent default-off flag.
# LENS_PATTERN_MINING_ENABLED=true
# LENS_PATTERN_EARNING_ENABLED=true
# LENS_PATTERN_CAPTURE_ENABLED=true

# ────────────────────────────────────────────────────────────
# OPTIONAL: log verbosity (debug, info, warn, error).
# ────────────────────────────────────────────────────────────
LENS_LOG_LEVEL=info
